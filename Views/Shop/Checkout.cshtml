@model List<Webstore.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
    Layout = "_ShopLayout";
    var total = Model.Sum(c => (c.Product?.Price ?? 0m) * c.Quantity);
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Cart">Giỏ hàng</a></li>
            <li class="breadcrumb-item active">Thanh toán</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Checkout Form -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-qrcode me-2"></i>Thông tin thanh toán
                    </h5>
                </div>
                <div class="card-body">
                    <form id="checkoutForm">
                        <!-- Customer Information -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h6 class="mb-3"><i class="fas fa-user me-2 text-primary"></i>Thông tin khách hàng</h6>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="customerName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="customerName" name="customerName" required placeholder="Nhập họ và tên của bạn">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="customerPhone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                <input type="tel" class="form-control" id="customerPhone" name="customerPhone" required placeholder="Nhập số điện thoại">
                            </div>
                            <div class="col-12 mb-3">
                                <label for="customerAddress" class="form-label">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                                <textarea class="form-control" id="customerAddress" name="customerAddress" rows="3" required placeholder="Nhập địa chỉ giao hàng đầy đủ"></textarea>
                            </div>
                        </div>

                        <!-- QR Payment -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h6 class="mb-3"><i class="fas fa-qrcode me-2 text-primary"></i>Phương thức thanh toán - QR Code</h6>
                            </div>
                            <div class="col-12">
                                <div class="qr-payment-container p-4 text-center">
                                    <div class="qr-wrapper mb-3">
                                        <div class="qr-box" id="qrBox">
                                            <div class="qr-inner">
                                                <div class="qr-scan-line"></div>
                                                <div class="qr-content">
                                                    <i class="fas fa-qrcode fa-4x text-primary mb-2"></i>
                                                    <p class="mb-0 text-muted small">Quét mã QR để thanh toán</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="alert alert-info d-flex align-items-center justify-content-center gap-2 mb-3">
                                        <i class="fas fa-info-circle"></i>
                                        <span>Quý khách vui lòng quét mã QR bên dưới bằng ứng dụng ngân hàng để thanh toán. Đơn hàng sẽ được xác nhận sau khi thanh toán thành công.</span>
                                    </div>

                                    <!-- Payment Account Info -->
                                    <div class="payment-info p-3 rounded" style="background:#f8f9fa; border:2px dashed #dee2e6;">
                                        <h6 class="mb-2"><i class="fas fa-university me-2"></i>Thông tin tài khoản</h6>
                                        <p class="mb-1"><strong>Ngân hàng:</strong> Vietcombank</p>
                                        <p class="mb-1"><strong>Số tài khoản:</strong> 1234567890</p>
                                        <p class="mb-1"><strong>Tên tài khoản:</strong> WEBSTORE SHOP</p>
                                        <p class="mb-0"><strong>Nội dung chuyển khoản:</strong> <code id="transferContent">WEBSTORE @DateTime.Now.ToString("yyyyMMddHHmmss")</code></p>
                                        <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="copyTransferContent()">
                                            <i class="fas fa-copy me-1"></i>Sao chép nội dung
                                        </button>
                                    </div>

                                    <!-- Hidden input for payment method -->
                                    <input type="hidden" name="paymentMethod" value="qr" />
                                </div>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="row">
                            <div class="col-12">
                                <h6 class="mb-3"><i class="fas fa-sticky-note me-2 text-primary"></i>Ghi chú đơn hàng</h6>
                                <textarea class="form-control" id="notes" name="notes" rows="2" placeholder="Ghi chú thêm cho đơn hàng (không bắt buộc)"></textarea>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <!-- Order Summary Card -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Đơn hàng của bạn</h5>
                </div>
                <div class="card-body p-0">
                    <!-- Order Items -->
                    <div class="order-items px-3 pt-3">
                        @foreach (var item in Model)
                        {
                            <div class="order-item mb-3 pb-3 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="product-image-small me-3">
                                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" style="width:100%;height:100%;object-fit:contain;border-radius:8px;" />
                                        }
                                        else
                                        {
                                            <i class="fas fa-box"></i>
                                        }
                                    </div>
                                    <div class="flex-grow-1" style="min-width:0;">
                                        <h6 class="mb-1" style="font-size:0.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.Product?.Name</h6>
                                        <small class="text-muted">x @item.Quantity</small>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold" style="font-size:0.9rem;">@(((item.Product?.Price ?? 0m) * item.Quantity).ToString("N0")) ₫</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="px-3 pb-3">
                        <!-- Order Summary -->
                        <div class="order-summary">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span>@Model.Sum(c => (c.Product?.Price ?? 0m) * c.Quantity).ToString("N0") ₫</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="text-success">Miễn phí</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-3">
                                <strong>Tổng cộng:</strong>
                                <strong class="text-danger fs-5">@total.ToString("N0") ₫</strong>
                            </div>
                        </div>

                        <!-- Place Order Button -->
                        <button type="button" class="btn btn-primary btn-lg w-100 mb-3" id="placeOrderBtn" onclick="placeOrder()">
                            <i class="fas fa-check-circle me-2"></i>Xác nhận đặt hàng
                        </button>

                        <!-- Security Notice -->
                        <div class="text-center">
                            <small class="text-muted d-flex align-items-center justify-content-center gap-1">
                                <i class="fas fa-shield-alt"></i>
                                Thông tin của bạn được bảo mật tuyệt đối
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Steps Guide -->
            <div class="card">
                <div class="card-header" style="background: #f8f9fa; color: #333;">
                    <h6 class="mb-0"><i class="fas fa-question-circle me-2"></i>Hướng dẫn thanh toán</h6>
                </div>
                <div class="card-body">
                    <div class="guide-step mb-3">
                        <div class="d-flex gap-3">
                            <div class="step-number">1</div>
                            <div>
                                <strong>Điền thông tin</strong>
                                <p class="mb-0 text-muted small">Nhập thông tin giao hàng chính xác</p>
                            </div>
                        </div>
                    </div>
                    <div class="guide-step mb-3">
                        <div class="d-flex gap-3">
                            <div class="step-number">2</div>
                            <div>
                                <strong>Quét mã QR</strong>
                                <p class="mb-0 text-muted small">Mở ứng dụng ngân hàng và quét mã</p>
                            </div>
                        </div>
                    </div>
                    <div class="guide-step">
                        <div class="d-flex gap-3">
                            <div class="step-number">3</div>
                            <div>
                                <strong>Xác nhận đặt hàng</strong>
                                <p class="mb-0 text-muted small">Nhấn nút xác nhận sau khi thanh toán thành công</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="mb-3"><i class="fas fa-headset me-2 text-primary"></i>Cần hỗ trợ?</h6>
                    <div class="contact-info">
                        <div class="contact-item mb-2">
                            <i class="fas fa-phone text-primary me-2"></i>
                            <small>0123 456 789</small>
                        </div>
                        <div class="contact-item mb-2">
                            <i class="fas fa-envelope text-primary me-2"></i>
                            <small>support@webstore.com</small>
                        </div>
                        <div class="contact-item">
                            <i class="fas fa-clock text-primary me-2"></i>
                            <small>Hỗ trợ 24/7</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    .card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0 !important;
        border: none;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
        padding: 0.75rem 1rem;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .product-image-small {
        width: 50px;
        height: 50px;
        background: #f8f9fa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #666;
        flex-shrink: 0;
    }

    .order-item {
        border-bottom: 1px solid #eee;
    }

    .order-item:last-child {
        border-bottom: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
        padding: 0.85rem;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .btn-primary:disabled {
        background: #ccc;
        border-color: #ccc;
        transform: none;
        box-shadow: none;
    }

    .contact-item {
        display: flex;
        align-items: center;
    }

    .text-danger {
        color: #e74c3c !important;
    }

    /* QR Payment Styles */
    .qr-payment-container {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        border: 2px solid #dee2e6;
    }

    .qr-wrapper {
        display: flex;
        justify-content: center;
    }

    .qr-box {
        width: 220px;
        height: 220px;
        background: white;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        position: relative;
        overflow: hidden;
    }

    .qr-inner {
        width: 100%;
        height: 100%;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .qr-scan-line {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #667eea, transparent);
        animation: scanLine 2s linear infinite;
    }

    @@keyframes scanLine {
        0% { top: 0; }
        50% { top: calc(100% - 3px); }
        100% { top: 0; }
    }

    .qr-content {
        text-align: center;
        z-index: 1;
    }

    .payment-info code {
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.9rem;
        display: inline-block;
    }

    .guide-step .step-number {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .alert-info {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.3);
        color: #333;
        border-radius: 10px;
    }

    .alert-info i {
        color: #667eea;
        font-size: 1.2rem;
    }
</style>

<script>
    function copyTransferContent() {
        const content = document.getElementById('transferContent').textContent;
        navigator.clipboard.writeText(content).then(function() {
            showToast('Đã sao chép nội dung chuyển khoản!', 'success');
        }).catch(function() {
            // Fallback for older browsers
            const textArea = document.createElement('textarea');
            textArea.value = content;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand('Copy');
            document.body.removeChild(textArea);
            showToast('Đã sao chép nội dung chuyển khoản!', 'success');
        });
    }

    function placeOrder() {
        const customerName = document.getElementById('customerName').value.trim();
        const customerPhone = document.getElementById('customerPhone').value.trim();
        const customerAddress = document.getElementById('customerAddress').value.trim();

        if (!customerName || !customerPhone || !customerAddress) {
            showToast('Vui lòng điền đầy đủ thông tin bắt buộc!', 'error');
            // Highlight empty fields
            if (!customerName) document.getElementById('customerName').style.borderColor = '#e74c3c';
            if (!customerPhone) document.getElementById('customerPhone').style.borderColor = '#e74c3c';
            if (!customerAddress) document.getElementById('customerAddress').style.borderColor = '#e74c3c';
            return;
        }

        // Reset border colors
        document.querySelectorAll('#checkoutForm .form-control').forEach(el => el.style.borderColor = '#e9ecef');

        const button = document.getElementById('placeOrderBtn');
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
        button.disabled = true;

        const orderData = {
            customerName: customerName,
            customerPhone: customerPhone,
            customerAddress: customerAddress,
            notes: document.getElementById('notes').value.trim(),
            paymentMethod: 'qr'
        };

        fetch('@Url.Action("PlaceOrder", "Shop")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(orderData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast('Đặt hàng thành công! Mã đơn hàng: #' + data.orderId, 'success');
                button.innerHTML = '<i class="fas fa-check-circle me-2"></i>Thành công!';
                button.classList.remove('btn-primary');
                button.classList.add('btn-success');

                setTimeout(() => {
                    window.location.href = '@Url.Action("Cart", "Shop")';
                }, 2000);
            } else {
                showToast(data.message || 'Có lỗi xảy ra, vui lòng thử lại', 'error');
                button.innerHTML = originalText;
                button.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
            button.innerHTML = originalText;
            button.disabled = false;
        });
    }

    function showToast(message, type) {
        const container = document.getElementById('toastContainer') || (function() {
            const div = document.createElement('div');
            div.id = 'toastContainer';
            div.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;max-width:350px;';
            document.body.appendChild(div);
            return div;
        })();

        const colors = {
            success: 'linear-gradient(135deg, #28a745 0%, #20c997 100%)',
            error: 'linear-gradient(135deg, #dc3545 0%, #c82333 100%)',
            warning: 'linear-gradient(135deg, #ffc107 0%, #e0a800 100%)',
            info: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
        };

        const icons = {
            success: 'fa-check-circle',
            error: 'fa-exclamation-circle',
            warning: 'fa-exclamation-triangle',
            info: 'fa-info-circle'
        };

        const toast = document.createElement('div');
        toast.style.cssText = 'background:' + colors[type] + ';color:white;padding:1rem 1.25rem;border-radius:12px;margin-bottom:10px;display:flex;align-items:center;gap:10px;box-shadow:0 5px 20px rgba(0,0,0,0.2);animation:slideIn 0.3s ease;';
        toast.innerHTML = '<i class="fas ' + icons[type] + '"></i><span style="flex:1">' + message + '</span><button onclick="this.parentElement.remove()" style="background:none;border:none;color:white;font-size:1.2rem;cursor:pointer;">&times;</button>';

        const style = document.createElement('style');
        style.textContent = '@@keyframes slideIn{from{opacity:0;transform:translateX(50px);}to{opacity:1;transform:translateX(0);}}';
        document.head.appendChild(style);

        container.appendChild(toast);

        setTimeout(() => {
            toast.style.animation = 'slideIn 0.3s ease reverse';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }

    // Clear error highlight on input
    document.querySelectorAll('#checkoutForm .form-control').forEach(el => {
        el.addEventListener('input', function() {
            this.style.borderColor = '#e9ecef';
        });
    });
</script>
