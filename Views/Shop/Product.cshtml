@model Webstore.Models.Product
@using System.Text.Json
@{
    ViewData["Title"] = Model.Name;
    Layout = "_ShopLayout";
    var fallbackDescriptionHtml = ProductDescriptionText.SanitizeDescriptionHtml("Sản phẩm chất lượng cao với thiết kế hiện đại, phù hợp cho mọi nhu cầu sử dụng. Được sản xuất với công nghệ tiên tiến và vật liệu cao cấp.");
    var descriptionHtml = string.IsNullOrWhiteSpace(Model.Description) ? fallbackDescriptionHtml : Model.Description;

    // Images for gallery (prefer DB/controller-provided list; fallback to ImageUrl; ensure at least 5 thumbnails)
    var productImages = (ViewBag.ProductImages as List<string>) ?? new List<string>();
    
    if (productImages.Count == 0 && !string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        productImages.Add(Model.ImageUrl!);
        
        // [Code mới] Tự động tìm thêm 4 ảnh phụ dựa trên tên file chính
        var mainImgPath = Model.ImageUrl!;
        var fileName = System.IO.Path.GetFileNameWithoutExtension(mainImgPath);
        var ext = System.IO.Path.GetExtension(mainImgPath);
        
        for (int i = 1; i <= 4; i++) {
            var extraUrl = $"/images/products/{fileName}__{i:02}.jpg";
            productImages.Add(extraUrl);
        }
    }
    
    if (productImages.Count == 0)
    {
        productImages.Add("/images/products/placeholder.svg");
    }
    
    var productImagesJson = JsonSerializer.Serialize(productImages);
}

<!-- Page Header -->
<div class="page-header-sm">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-light">
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Products">Sản phẩm</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Products" asp-route-categoryId="@Model.CategoryId">@(Model.Category?.Name ?? "Danh mục")</a></li>
                <li class="breadcrumb-item active">@(Model.Name)</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <!-- Product Image Gallery (Full Implementation) -->
        <div class="col-lg-6 mb-4">
            <div class="product-gallery-container">
                <!-- 1. Ảnh chính lớn -->
                <div class="gallery-main" id="galleryMain">
                    <div class="zoom-lens" id="zoomLens"></div>
                    
                    <!-- 4. Nút Next/Prev -->
                    <button class="nav-btn prev" onclick="prevSlide()"><i class="fas fa-chevron-left"></i></button>
                    <button class="nav-btn next" onclick="nextSlide()"><i class="fas fa-chevron-right"></i></button>
                    
                    <div class="main-image-wrapper">
                        <img id="currentMainImg" src="@Model.ImageUrl" alt="@Model.Name" />
                    </div>

                    <!-- 8. Zoom Result (Sẽ hiện khi hover) -->
                    <div id="zoomResult" class="zoom-result"></div>
                </div>

                <!-- 2. Danh sách Thumbnails -->
                <div class="gallery-thumbs" id="thumbContainer">
                    <!-- Sẽ được render bởi JavaScript từ mảng dữ liệu -->
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-6">
            <div class="product-detail-card">
                <div class="detail-header">
                    <div class="detail-category">@Model.Category?.Name</div>
                    <h1 class="detail-title">@(Model.Name)</h1>
                    <div class="detail-rating">
                        <span class="stars">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                        </span>
                        <span class="rating-text">4.5 (128 đánh giá)</span>
                    </div>
                </div>

                <div class="detail-price-section">
                    <div class="detail-price" id="displayPrice">@Model.Price.ToString("N0") ₫</div>
                    <div class="detail-price-note" id="displayOriginalPrice">
                        @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
                        {
                            <del>@Model.OriginalPrice.Value.ToString("N0") ₫</del>
                            <span class="badge bg-danger ms-2">-@Model.DiscountPercent%</span>
                        }
                    </div>
                </div>

                <!-- Variant Selection -->
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <div class="variant-selection-container mt-4">
                        @if (Model.Variants.Any(v => !string.IsNullOrEmpty(v.Storage) || !string.IsNullOrEmpty(v.RAM)))
                        {
                            <div class="variant-group mb-3">
                                <label class="variant-label fw-bold mb-2">Chọn phiên bản cấu hình:</label>
                                <div class="variant-options d-flex flex-wrap gap-2">
                                    @foreach (var vGroup in Model.Variants.GroupBy(v => v.Storage + (string.IsNullOrEmpty(v.RAM) ? "" : " / " + v.RAM)).OrderBy(g => g.First().Price))
                                    {
                                        <button type="button" class="btn btn-outline-primary variant-option-btn config-btn" 
                                                data-config="@vGroup.Key" 
                                                onclick="selectConfig('@vGroup.Key')">
                                            @vGroup.Key
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @if (Model.Variants.Any(v => !string.IsNullOrEmpty(v.Color)))
                        {
                            <div class="variant-group mb-3">
                                <label class="variant-label fw-bold mb-2">Chọn màu sắc:</label>
                                <div class="variant-options d-flex flex-wrap gap-2">
                                    @foreach (var color in Model.Variants.Select(v => v.Color).Distinct())
                                    {
                                        <button type="button" class="btn btn-outline-secondary variant-option-btn color-btn" 
                                                data-color="@color"
                                                onclick="selectColor('@color')">
                                            @color
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <input type="hidden" id="selectedVariantId" value="" />
                }

                <div class="detail-desc">
                    <h6><i class="fas fa-info-circle me-2"></i>Mô tả sản phẩm</h6>
                    <div class="product-description-content">@Html.Raw(descriptionHtml)</div>
                </div>

                <div class="detail-meta">
                    <div class="meta-item">
                        <i class="fas fa-check-circle text-success" id="stockStatusIcon"></i>
                        <span id="stockStatusText">@(Model.StockQuantity > 0 ? "Còn hàng" : "Hết hàng")</span>
                    </div>
                    <!-- ... other meta items ... -->
                </div>

                <!-- Quantity -->
                <div class="detail-quantity">
                    <label class="qty-label">Số lượng</label>
                    <div class="qty-controls">
                        <button type="button" class="qty-btn" onclick="decreaseQty()"><i class="fas fa-minus"></i></button>
                        <input type="number" id="quantity" class="qty-input" value="1" min="1" max="10" readonly>
                        <button type="button" class="qty-btn" onclick="increaseQty()"><i class="fas fa-plus"></i></button>
                    </div>
                </div>

                <!-- Actions -->
                <div class="detail-actions">
                    <button class="btn btn-add-to-cart" id="btnAddToCart" onclick="addToCartWithQty()">
                        <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                    </button>
                    <button class="btn btn-buy-now" onclick="buyNow()">
                        <i class="fas fa-bolt me-2"></i>Mua ngay
                    </button>
                </div>

                <!-- Features -->
                <div class="detail-features">
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-shipping-fast"></i></div>
                        <div>
                            <strong>Giao hàng nhanh</strong>
                            <small>Giao trong 24h nội thành</small>
                        </div>
                    </div>
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <strong>Bảo hành 12 tháng</strong>
                            <small>Chính hãng toàn quốc</small>
                        </div>
                    </div>
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-headset"></i></div>
                        <div>
                            <strong>Hỗ trợ 24/7</strong>
                            <small>Tư vấn mọi lúc</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Info Tabs -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="product-tabs">
                <div class="tabs-header">
                    <button class="tab-btn active" data-tab="description">
                        <i class="fas fa-info-circle me-2"></i>Mô tả chi tiết
                    </button>
                    <button class="tab-btn" data-tab="specs">
                        <i class="fas fa-cogs me-2"></i>Thông số kỹ thuật
                    </button>
                    <button class="tab-btn" data-tab="reviews">
                        <i class="fas fa-star me-2"></i>Đánh giá (128)
                    </button>
                </div>
                <div class="tabs-content">
                    <div class="tab-pane active" id="description">
                        <div class="tab-content-card">
                            <h5>Mô tả chi tiết sản phẩm</h5>
                            <div class="product-description-content">@Html.Raw(descriptionHtml)</div>
                            <ul>
                                <li>Chất liệu cao cấp, bền đẹp theo thời gian</li>
                                <li>Thiết kế hiện đại, sang trọng</li>
                                <li>Dễ dàng sử dụng và bảo quản</li>
                                <li>Phù hợp cho mọi lứa tuổi</li>
                                <li>Bảo hành chính hãng 12 tháng</li>
                            </ul>
                        </div>
                    </div>
                    <div class="tab-pane" id="specs">
                        <div class="tab-content-card">
                            <h5>Thông số kỹ thuật</h5>
                            <table class="specs-table">
                                <tr><td><strong>Danh mục</strong></td><td>@(Model.Category?.Name ?? "Không có")</td></tr>
                                <tr><td><strong>Nhà cung cấp</strong></td><td>@(Model.Supplier?.Name ?? "Không có")</td></tr>
                                <tr><td><strong>Mã sản phẩm</strong></td><td>#@Model.ProductId</td></tr>
                            </table>
                        </div>
                    </div>
                    <div class="tab-pane" id="reviews">
                        <div class="tab-content-card">
                            <div class="review-summary">
                                <div class="review-score">
                                    <div class="score-number">4.5</div>
                                    <div class="score-stars">
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star-half-alt"></i>
                                    </div>
                                    <div class="score-count">128 đánh giá</div>
                                </div>
                            </div>
                            <hr>
                            <div class="review-item">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">N</div>
                                    <div>
                                        <strong>Nguyễn Văn A</strong>
                                        <div class="review-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                                    </div>
                                </div>
                                <p class="review-text">Sản phẩm rất tốt, chất lượng cao. Giao hàng nhanh, đóng gói cẩn thận. Sẽ ủng hộ tiếp!</p>
                                <small class="text-muted">2 ngày trước</small>
                            </div>
                            <div class="review-item">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">T</div>
                                    <div>
                                        <strong>Trần Thị B</strong>
                                        <div class="review-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i></div>
                                    </div>
                                </div>
                                <p class="review-text">Tốt, đúng như mô tả. Sẽ mua lại lần sau.</p>
                                <small class="text-muted">1 tuần trước</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (ViewBag.RelatedProducts != null && ((List<Webstore.Models.Product>)ViewBag.RelatedProducts).Any())
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-th-large"></i> Sản phẩm liên quan</h2>
                </div>
                <div class="row g-4">
                    @foreach (var product in ViewBag.RelatedProducts)
                    {
                        <div class="col-lg-3 col-md-6">
                            <div class="product-card">
                                <a asp-controller="Shop" asp-action="Product" asp-route-id="@product.ProductId" class="product-card-img">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" />
                                    }
                                    else
                                    {
                                        <div class="img-placeholder">
                                            <i class="fas fa-box" style="font-size:3rem;"></i>
                                            <span class="placeholder-name">@(product.Name)</span>
                                        </div>
                                    }
                                    <div class="product-overlay"><i class="fas fa-eye"></i></div>
                                </a>
                                <div class="product-card-body">
                                    <div class="product-card-cat">@product.Category?.Name</div>
                                    <h5 class="product-card-title">
                                        <a asp-controller="Shop" asp-action="Product" asp-route-id="@product.ProductId">@product.Name</a>
                                    </h5>
                                    <div class="product-card-price">@product.Price.ToString("N0") ₫</div>
                                    <button class="btn btn-add-cart" onclick="addToCart(@product.ProductId)">
                                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Page Header */
    .page-header-sm {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        padding: 16px 0;
    }

    /* --- PRODUCT GALLERY STYLES --- */
    .product-gallery-container {
        position: sticky;
        top: 100px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* 1. Main Display */
    .gallery-main {
        position: relative;
        width: 100%;
        aspect-ratio: 1;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-image-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-image-wrapper img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: opacity 0.4s ease; /* 6. Hiệu ứng mượt */
    }

    /* 4. Navigation Buttons - Đẩy ra 2 bên sát mép */
    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 45px;
        height: 45px;
        background: rgba(255,255,255,0.8);
        border: 1px solid var(--border);
        border-radius: 50%;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 10;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-primary);
        backdrop-filter: blur(4px);
    }
    .nav-btn:hover { 
        background: var(--primary); 
        color: white; 
        border-color: var(--primary);
        box-shadow: 0 6px 20px rgba(0, 119, 182, 0.3);
    }
    .nav-btn.prev { left: 10px; }
    .nav-btn.next { right: 10px; }

    @@media (max-width: 991px) {
        #zoom-result { display: none !important; }
        .gallery-main-viewport { cursor: default; }
    }

    /* Detail Card */
    .product-detail-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 28px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border);
    }
    .detail-category {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }
    .detail-title {
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 10px;
        line-height: 1.3;
    }
    .detail-rating {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
    .stars { color: #F59E0B; font-size: 0.9rem; }
    .rating-text { font-size: 0.85rem; color: var(--text-muted); }
    .detail-price-section {
        background: linear-gradient(135deg, var(--primary-lightest) 0%, white 100%);
        border-radius: var(--radius-md);
        padding: 16px 20px;
        margin-bottom: 20px;
        border-left: 4px solid var(--primary);
    }
    .detail-price {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
    }
    .detail-price-note {
        font-size: 0.78rem;
        color: var(--text-muted);
    }
    .detail-desc {
        margin-bottom: 20px;
    }
    .detail-desc h6 {
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--text-primary);
    }
    .detail-desc p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7; }
    .product-description-content p,
    .product-description-content ul,
    .product-description-content ol {
        margin-bottom: 0.75rem;
        color: var(--text-secondary);
        line-height: 1.7;
    }
    .product-description-content ul,
    .product-description-content ol {
        padding-left: 1.2rem;
    }
    .detail-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-secondary);
    }
    .detail-quantity {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
    }
    .qty-label {
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-primary);
        white-space: nowrap;
        margin: 0;
    }
    .qty-controls {
        display: flex;
        align-items: center;
        border: 2px solid var(--border);
        border-radius: var(--radius-md);
        overflow: hidden;
    }
    .qty-btn {
        width: 40px; height: 40px;
        border: none;
        background: var(--surface-alt);
        color: var(--text-secondary);
        font-size: 0.85rem;
        cursor: pointer;
        transition: var(--transition);
    }
    .qty-btn:hover { background: var(--primary-lightest); color: var(--primary); }
    .qty-input {
        width: 50px; height: 40px;
        border: none;
        text-align: center;
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--text-primary);
        background: white;
    }
    .qty-input:focus { outline: none; }
    .detail-actions {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
    }
    .btn-add-to-cart {
        flex: 1;
        padding: 14px 20px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        border: none;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: var(--transition);
    }
    .btn-add-to-cart:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 119, 182, 0.35);
    }
    .btn-buy-now {
        flex: 1;
        padding: 14px 20px;
        background: white;
        color: var(--primary);
        border: 2px solid var(--primary);
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: var(--transition);
    }
    .btn-buy-now:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
    }
    .detail-features {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }
    .feature-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .feature-icon-sm {
        width: 36px; height: 36px;
        background: var(--primary-lightest);
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem;
        color: var(--primary);
        flex-shrink: 0;
    }
    .feature-row strong { display: block; font-size: 0.88rem; font-weight: 700; }
    .feature-row small { font-size: 0.75rem; color: var(--text-muted); }

    /* Tabs */
    .product-tabs {
        background: white;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        overflow: hidden;
    }
    .tabs-header {
        display: flex;
        border-bottom: 2px solid var(--border);
        background: var(--surface-alt);
    }
    .tab-btn {
        flex: 1;
        padding: 14px 16px;
        border: none;
        background: transparent;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--text-muted);
        cursor: pointer;
        transition: var(--transition);
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
    }
    .tab-btn:hover { color: var(--primary); background: var(--primary-lightest); }
    .tab-btn.active {
        color: var(--primary);
        border-bottom-color: var(--primary);
        background: white;
    }
    .tabs-content { padding: 0; }
    .tab-pane { display: none; padding: 24px; }
    .tab-pane.active { display: block; }
    .tab-content-card { }
    .tab-content-card h5 { font-weight: 800; margin-bottom: 14px; }
    .tab-content-card ul { padding-left: 20px; }
    .tab-content-card li { margin-bottom: 8px; color: var(--text-secondary); }
    .specs-table { width: 100%; }
    .specs-table td { padding: 10px 0; border-bottom: 1px solid var(--border); }
    .specs-table td:first-child { width: 40%; color: var(--text-muted); font-size: 0.88rem; }
    .specs-table td:last-child { font-weight: 600; }

    /* Reviews */
    .review-summary {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 20px;
    }
    .review-score { text-align: center; }
    .score-number { font-size: 3rem; font-weight: 800; color: var(--primary); line-height: 1; }
    .score-stars { color: #F59E0B; margin: 4px 0; }
    .score-count { font-size: 0.82rem; color: var(--text-muted); }
    .review-item {
        border-bottom: 1px solid var(--border);
        padding: 16px 0;
    }
    .review-item:last-child { border-bottom: none; }
    .reviewer-info { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .reviewer-avatar {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; font-weight: 700; font-size: 0.85rem;
    }
    .reviewer-info strong { font-size: 0.9rem; }
    .review-stars { color: #F59E0B; font-size: 0.78rem; }
    .review-text { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 4px; }

    /* Breadcrumb light variant for product page */
    .breadcrumb-light {
        background: transparent;
        padding: 0;
        margin: 0;
        font-size: 0.85rem;
    }
    .breadcrumb-light .breadcrumb-item a {
        color: rgba(255,255,255,0.7);
        transition: color 0.2s;
    }
    .breadcrumb-light .breadcrumb-item a:hover {
        color: white;
    }
    .breadcrumb-light .breadcrumb-item + .breadcrumb-item::before {
        color: rgba(255,255,255,0.5);
    }
    .breadcrumb-light .breadcrumb-item.active {
        color: white;
    }
</style>

<script>
    // Variants Data
    const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model.Variants ?? Enumerable.Empty<Webstore.Models.ProductVariant>()).Select(v => new {
        v.VariantId,
        v.Color,
        v.Storage,
        v.RAM,
        v.Price,
        v.OriginalPrice,
        v.StockQuantity,
        config = v.Storage + (string.IsNullOrEmpty(v.RAM) ? "" : " / " + v.RAM)
    })));

    let selectedConfig = null;
    let selectedColor = null;

    function selectConfig(config) {
        selectedConfig = config;
        document.querySelectorAll('.config-btn').forEach(btn => {
            btn.classList.toggle('active', btn.getAttribute('data-config') === config);
            btn.classList.toggle('btn-primary', btn.getAttribute('data-config') === config);
            btn.classList.toggle('btn-outline-primary', btn.getAttribute('data-config') !== config);
        });
        updateVariantInfo();
    }

    function selectColor(color) {
        selectedColor = color;
        document.querySelectorAll('.color-btn').forEach(btn => {
            btn.classList.toggle('active', btn.getAttribute('data-color') === color);
            btn.classList.toggle('btn-secondary', btn.getAttribute('data-color') === color);
            btn.classList.toggle('btn-outline-secondary', btn.getAttribute('data-color') !== color);
        });
        updateVariantInfo();
    }

    function updateVariantInfo() {
        const match = variants.find(v => 
            (!selectedConfig || v.config === selectedConfig) && 
            (!selectedColor || v.Color === selectedColor)
        );

        if (match) {
            document.getElementById('selectedVariantId').value = match.VariantId;
            document.getElementById('displayPrice').innerText = match.Price.toLocaleString('vi-VN') + ' ₫';
            
            const originalPriceEl = document.getElementById('displayOriginalPrice');
            if (match.OriginalPrice && match.OriginalPrice > match.Price) {
                const discount = Math.round((1 - match.Price / match.OriginalPrice) * 100);
                originalPriceEl.innerHTML = `<del>${match.OriginalPrice.toLocaleString('vi-VN')} ₫</del><span class="badge bg-danger ms-2">-${discount}%</span>`;
            } else {
                originalPriceEl.innerHTML = '';
            }

            // Update stock status
            const stockIcon = document.getElementById('stockStatusIcon');
            const stockText = document.getElementById('stockStatusText');
            const cartBtn = document.getElementById('btnAddToCart');

            if (match.StockQuantity > 0) {
                stockIcon.className = 'fas fa-check-circle text-success';
                stockText.innerText = 'Còn hàng (' + match.StockQuantity + ')';
                cartBtn.disabled = false;
            } else {
                stockIcon.className = 'fas fa-times-circle text-danger';
                stockText.innerText = 'Hết hàng';
                cartBtn.disabled = true;
            }
        }
    }

    // Auto-select first variant on load
    window.addEventListener('DOMContentLoaded', () => {
        if (variants.length > 0) {
            selectConfig(variants[0].config);
            selectColor(variants[0].Color);
        }
    });

    function increaseQty() {
        const input = document.getElementById('quantity');
        let val = parseInt(input.value);
        if (val < 10) input.value = val + 1;
    }
    function decreaseQty() {
        const input = document.getElementById('quantity');
        let val = parseInt(input.value);
        if (val > 1) input.value = val - 1;
    }
    function addToCartWithQty() {
        const productId = @Model.ProductId;
        const qty = parseInt(document.getElementById('quantity').value);
        const variantId = document.getElementById('selectedVariantId').value;
        
        // Use a more detailed addToCart that handles variantId
        $.ajax({
            url: '@Url.Action("AddToCart", "Shop")',
            type: 'POST',
            data: { productId, quantity: qty, variantId },
            success: function(res) {
                if(res.success) {
                    showToast("Đã thêm vào giỏ hàng!");
                    updateCartBadge(res.cartCount);
                } else if(res.requiresLogin) {
                    window.location.href = '@Url.Action("Login", "Auth")?returnUrl=' + encodeURIComponent(window.location.href);
                } else {
                    showToast(res.message, "error");
                }
            }
        });
    }
    function buyNow() {
        addToCartWithQty();
        setTimeout(function() { window.location.href = '@Url.Action("Cart", "Shop")'; }, 800);
    }

    // 9. Dữ liệu ảnh sản phẩm - LOẠI BỎ ẢNH TRÙNG
    const rawImages = @Html.Raw(JsonSerializer.Serialize(productImages));
    const productImages = [...new Set(rawImages)]; // Chỉ giữ lại các ảnh duy nhất
    let currentIndex = 0;

    // Render Thumbnails ban đầu
    function renderThumbs() {
        const container = document.getElementById('thumbContainer');
        container.innerHTML = productImages.map((img, idx) => `
            <div class="thumb-item ${idx === 0 ? 'active' : ''}" onclick="changeSlide(${idx})">
                <img src="${img}" onerror="this.src='/images/products/placeholder.svg'" />
            </div>
        `).join('');
    }

    // 3. Xử lý đổi ảnh khi click thumbnail
    function changeSlide(index) {
        if (index < 0) index = productImages.length - 1;
        if (index >= productImages.length) index = 0;
        
        currentIndex = index;
        const mainImg = document.getElementById('currentMainImg');
        
        // 6. Hiệu ứng mượt (Fade out -> change src -> Fade in)
        mainImg.style.opacity = '0';
        setTimeout(() => {
            mainImg.src = productImages[currentIndex];
            mainImg.style.opacity = '1';
            updateThumbHighlight();
            initZoomLogic(); // Re-init zoom for new image
        }, 200);
    }

    // 4. Slider Nav
    function nextSlide() { changeSlide(currentIndex + 1); }
    function prevSlide() { changeSlide(currentIndex - 1); }

    // 5. Cập nhật viền Highlight
    function updateThumbHighlight() {
        document.querySelectorAll('.thumb-item').forEach((thumb, idx) => {
            thumb.classList.toggle('active', idx === currentIndex);
        });
    }

    // 8. Zoom Lens Logic
    function initZoomLogic() {
        const mainImg = document.getElementById('currentMainImg');
        const lens = document.getElementById('zoomLens');
        const result = document.getElementById('zoomResult');
        const container = document.getElementById('galleryMain');

        if (window.innerWidth < 992) return;

        container.onmouseenter = () => {
            lens.style.display = "block";
            result.style.display = "block";
        };
        container.onmouseleave = () => {
            lens.style.display = "none";
            result.style.display = "none";
        };

        result.style.backgroundImage = `url('${mainImg.src}')`;
        const zoomLevel = 2.5;
        result.style.backgroundSize = (mainImg.offsetWidth * zoomLevel) + "px " + (mainImg.offsetHeight * zoomLevel) + "px";

        container.onmousemove = (e) => {
            const rect = mainImg.getBoundingClientRect();
            let x = e.pageX - rect.left - window.pageXOffset - (lens.offsetWidth / 2);
            let y = e.pageY - rect.top - window.pageYOffset - (lens.offsetHeight / 2);

            // Giới hạn trong ảnh
            if (x > mainImg.offsetWidth - lens.offsetWidth) x = mainImg.offsetWidth - lens.offsetWidth;
            if (x < 0) x = 0;
            if (y > mainImg.offsetHeight - lens.offsetHeight) y = mainImg.offsetHeight - lens.offsetHeight;
            if (y < 0) y = 0;

            lens.style.left = x + "px";
            lens.style.top = y + "px";

            // Di chuyển background của result
            const cx = result.offsetWidth / lens.offsetWidth;
            const cy = result.offsetHeight / lens.offsetHeight;
            result.style.backgroundPosition = "-" + (x * cx) + "px -" + (y * cy) + "px";
        };
    }

    // Khởi tạo khi load trang
    window.addEventListener('DOMContentLoaded', () => {
        renderThumbs();
        initZoomLogic();
    });
</script>

