@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="admin-page-header">
    <h1 class="admin-page-title"><i class="fas fa-tachometer-alt me-2" style="color:var(--primary);"></i>Dashboard</h1>
    <p class="admin-page-subtitle">Chào mừng bạn quay trở lại! Dưới đây là tổng quan hệ thống.</p>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Products" asp-action="Create" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#0077B6,#00B4D8);"><i class="fas fa-plus"></i></div>
            <div class="qa-label">Thêm sản phẩm</div>
        </a>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Orders" asp-action="Create" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#10B981,#34D399);"><i class="fas fa-shopping-bag"></i></div>
            <div class="qa-label">Tạo đơn hàng</div>
        </a>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Categories" asp-action="Create" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#3B82F6,#60A5FA);"><i class="fas fa-tags"></i></div>
            <div class="qa-label">Thêm danh mục</div>
        </a>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Accounts" asp-action="Create" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#8B5CF6,#A78BFA);"><i class="fas fa-user-plus"></i></div>
            <div class="qa-label">Thêm tài khoản</div>
        </a>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Suppliers" asp-action="Create" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#F59E0B,#FBBF24);"><i class="fas fa-truck"></i></div>
            <div class="qa-label">Thêm nhà cung cấp</div>
        </a>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <a asp-controller="Statistics" asp-action="Index" class="quick-action-card">
            <div class="qa-icon" style="background:linear-gradient(135deg,#EF4444,#F87171);"><i class="fas fa-chart-line"></i></div>
            <div class="qa-label">Xem thống kê</div>
        </a>
    </div>
</div>

<!-- Stats Grid -->
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="stats-card">
            <div class="stats-icon" style="background:linear-gradient(135deg,#0077B6,#00B4D8);color:white;">
                <i class="fas fa-box"></i>
            </div>
            <div class="stats-info">
                <strong>@ViewBag.ProductCount</strong>
                <span>Sản phẩm</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stats-card">
            <div class="stats-icon" style="background:linear-gradient(135deg,#10B981,#34D399);color:white;">
                <i class="fas fa-shopping-bag"></i>
            </div>
            <div class="stats-info">
                <strong>@ViewBag.OrderCount</strong>
                <span>Đơn hàng</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stats-card">
            <div class="stats-icon" style="background:linear-gradient(135deg,#8B5CF6,#A78BFA);color:white;">
                <i class="fas fa-users"></i>
            </div>
            <div class="stats-info">
                <strong>@ViewBag.AccountCount</strong>
                <span>Tài khoản</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="stats-card">
            <div class="stats-icon" style="background:linear-gradient(135deg,#F59E0B,#FBBF24);color:white;">
                <i class="fas fa-truck"></i>
            </div>
            <div class="stats-info">
                <strong>@ViewBag.SupplierCount</strong>
                <span>Nhà cung cấp</span>
            </div>
        </div>
    </div>
</div>

<!-- Features -->
<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-bolt me-2"></i>Thao tác nhanh</div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary"><i class="fas fa-box me-2"></i>Quản lý sản phẩm</a>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-success"><i class="fas fa-shopping-bag me-2"></i>Quản lý đơn hàng</a>
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-info"><i class="fas fa-tags me-2"></i>Quản lý danh mục</a>
                    <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-warning"><i class="fas fa-truck me-2"></i>Quản lý nhà cung cấp</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-star me-2"></i>Tính năng nổi bật</div>
            <div class="card-body">
                <div class="feature-mini-list">
                    <div class="fmini-item">
                        <div class="fmini-icon"><i class="fas fa-chart-line"></i></div>
                        <div><strong>Báo cáo thống kê</strong><br><small class="text-muted">Theo dõi doanh thu, sản phẩm bán chạy</small></div>
                    </div>
                    <div class="fmini-item">
                        <div class="fmini-icon"><i class="fas fa-mobile-alt"></i></div>
                        <div><strong>Responsive Design</strong><br><small class="text-muted">Giao diện tối ưu mọi thiết bị</small></div>
                    </div>
                    <div class="fmini-item">
                        <div class="fmini-icon"><i class="fas fa-shield-alt"></i></div>
                        <div><strong>Bảo mật cao</strong><br><small class="text-muted">Phân quyền người dùng đa cấp</small></div>
                    </div>
                    <div class="fmini-item">
                        <div class="fmini-icon"><i class="fas fa-sync-alt"></i></div>
                        <div><strong>Đồng bộ thời gian thực</strong><br><small class="text-muted">Cập nhật dữ liệu ngay lập tức</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-12">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-store me-2"></i>Cửa hàng</div>
            <div class="card-body d-flex flex-column justify-content-center text-center">
                <div style="font-size:3rem; color:var(--primary); margin-bottom:12px;">
                    <i class="fas fa-store"></i>
                </div>
                <h5 class="fw-bold mb-2">Truy cập cửa hàng</h5>
                <p class="text-muted mb-3">Xem và quản lý giao diện cửa hàng của bạn</p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-auto">
                    <i class="fas fa-external-link-alt me-2"></i>Mở cửa hàng
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .quick-action-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        text-align: center;
        text-decoration: none;
        color: var(--text-primary);
        transition: var(--transition);
    }
    .quick-action-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-lighter);
        color: var(--primary);
    }
    .qa-icon {
        width: 44px; height: 44px;
        border-radius: var(--radius-md);
        display: flex; align-items: center; justify-content: center;
        color: white;
        font-size: 1rem;
    }
    .qa-label { font-size: 0.78rem; font-weight: 700; }

    .feature-mini-list { display: flex; flex-direction: column; gap: 12px; }
    .fmini-item { display: flex; align-items: flex-start; gap: 12px; }
    .fmini-icon {
        width: 36px; height: 36px;
        background: var(--primary-lightest);
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        color: var(--primary);
        font-size: 0.85rem;
        flex-shrink: 0;
    }
    .fmini-item strong { font-size: 0.85rem; }
    .fmini-item small { font-size: 0.75rem; }
</style>
