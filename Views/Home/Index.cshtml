@{
    ViewData["Title"] = "Trang Chủ - Webstore";
}

<!-- Hero Section -->
<div class="hero-section bg-gradient-primary text-white py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">Chào mừng đến với Webstore</h1>
                <p class="lead mb-4">Hệ thống quản lý cửa hàng trực tuyến hiện đại với đầy đủ tính năng quản lý sản phẩm, đơn hàng và kho hàng.</p>
                <div class="d-flex gap-3">
                    <a href="#features" class="btn btn-light btn-lg">Khám phá</a>
                    <a href="#dashboard" class="btn btn-outline-light btn-lg">Bảng điều khiển</a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="fas fa-store fa-10x opacity-75"></i>
            </div>
        </div>
    </div>
</div>

<!-- Dashboard Cards -->
<div id="dashboard" class="container mb-5">
    <h2 class="text-center mb-5">Bảng Điều Khiển</h2>
    <div class="row g-4">
        <!-- Products Card -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="bg-primary bg-gradient rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-box text-white fa-2x"></i>
                        </div>
                    </div>
                    <h5 class="card-title">Sản Phẩm</h5>
                    <p class="card-text text-muted flex-grow-1">Quản lý danh mục sản phẩm, giá cả và thông tin chi tiết</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-auto">Quản lý</a>
                </div>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="bg-success bg-gradient rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-shopping-cart text-white fa-2x"></i>
                        </div>
                    </div>
                    <h5 class="card-title">Đơn Hàng</h5>
                    <p class="card-text text-muted flex-grow-1">Theo dõi và xử lý đơn hàng từ khách hàng</p>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-success mt-auto">Quản lý</a>
                </div>
            </div>
        </div>

        <!-- Inventory Card -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="bg-warning bg-gradient rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-warehouse text-white fa-2x"></i>
                        </div>
                    </div>
                    <h5 class="card-title">Kho Hàng</h5>
                    <p class="card-text text-muted flex-grow-1">Quản lý tồn kho và nhập/xuất hàng</p>
                    <a asp-controller="Inventory" asp-action="Index" class="btn btn-warning mt-auto">Quản lý</a>
                </div>
            </div>
        </div>

        <!-- Customers Card -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4 d-flex flex-column">
                    <div class="d-flex justify-content-center mb-3">
                        <div class="bg-info bg-gradient rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-users text-white fa-2x"></i>
                        </div>
                    </div>
                    <h5 class="card-title">Khách Hàng</h5>
                    <p class="card-text text-muted flex-grow-1">Quản lý tài khoản và thông tin khách hàng</p>
                    <a asp-controller="Accounts" asp-action="Index" class="btn btn-info mt-auto">Quản lý</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div id="features" class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-5">Tính Năng Nổi Bật</h2>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="text-center">
                    <div class="bg-primary bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-chart-line text-white fa-3x"></i>
                    </div>
                    <h4>Báo Cáo Thống Kê</h4>
                    <p class="text-muted">Theo dõi doanh thu, sản phẩm bán chạy và xu hướng kinh doanh</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="text-center">
                    <div class="bg-success bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-mobile-alt text-white fa-3x"></i>
                    </div>
                    <h4>Responsive Design</h4>
                    <p class="text-muted">Giao diện tối ưu cho mọi thiết bị từ desktop đến mobile</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="text-center">
                    <div class="bg-warning bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-shield-alt text-white fa-3x"></i>
                    </div>
                    <h4>Bảo Mật Cao</h4>
                    <p class="text-muted">Hệ thống bảo mật đa lớp với phân quyền người dùng</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="text-center">
                    <div class="bg-info bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-sync-alt text-white fa-3x"></i>
                    </div>
                    <h4>Đồng Bộ Thời Gian Thực</h4>
                    <p class="text-muted">Cập nhật dữ liệu ngay lập tức trên toàn hệ thống</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="text-center">
                    <div class="bg-danger bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-search text-white fa-3x"></i>
                    </div>
                    <h4>Tìm Kiếm Thông Minh</h4>
                    <p class="text-muted">Tìm kiếm nhanh chóng với bộ lọc đa tiêu chí</p>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
<div class="text-center">
                    <div class="bg-secondary bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-cogs text-white fa-3x"></i>
                    </div>
                    <h4>Dễ Sử Dụng</h4>
                    <p class="text-muted">Giao diện trực quan, dễ dàng sử dụng cho mọi người</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="container py-5">
    <h2 class="text-center mb-5">Thao Tác Nhanh</h2>
    <div class="row g-3">
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary w-100 py-3">
                <i class="fas fa-plus d-block mb-2"></i>
                Thêm Sản Phẩm
            </a>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Orders" asp-action="Create" class="btn btn-outline-success w-100 py-3">
                <i class="fas fa-shopping-cart d-block mb-2"></i>
                Tạo Đơn Hàng
            </a>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Inventory" asp-action="Create" class="btn btn-outline-warning w-100 py-3">
                <i class="fas fa-warehouse d-block mb-2"></i>
                Nhập Kho
            </a>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Accounts" asp-action="Create" class="btn btn-outline-info w-100 py-3">
                <i class="fas fa-user-plus d-block mb-2"></i>
                Thêm Khách Hàng
            </a>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Categories" asp-action="Create" class="btn btn-outline-secondary w-100 py-3">
                <i class="fas fa-tags d-block mb-2"></i>
                Thêm Danh Mục
            </a>
        </div>
        <div class="col-lg-2 col-md-4 col-sm-6">
            <a asp-controller="Suppliers" asp-action="Create" class="btn btn-outline-dark w-100 py-3">
                <i class="fas fa-truck d-block mb-2"></i>
                Thêm Nhà Cung Cấp
            </a>
        </div>
    </div>
</div>

<!-- Statistics Section -->
<div class="bg-primary text-white py-5">
    <div class="container">
        <h2 class="text-center mb-5">Thống Kê Tổng Quan</h2>
        <div class="row text-center">
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="h1 fw-bold">150+</div>
                <div class="h5">Sản Phẩm</div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="h1 fw-bold">500+</div>
                <div class="h5">Đơn Hàng</div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="h1 fw-bold">1000+</div>
                <div class="h5">Khách Hàng</div>
            </div>
            <div class="col-lg-3 col-md-6 mb-4">
                <div class="h1 fw-bold">99%</div>
                <div class="h5">Hài Lòng</div>
            </div>
        </div>
    </div>
</div>

<!-- Auth Section -->
<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h2 class="fw-bold mb-4">Bắt đầu ngay hôm nay!</h2>
            <p class="lead mb-4">Tham gia cùng hàng nghìn khách hàng đã tin tưởng sử dụng Webstore để quản lý cửa hàng của họ.</p>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg">
                    <i class="fas fa-user-plus me-2"></i>Tạo tài khoản miễn phí
                </a>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-primary btn-lg">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </a>
            </div>
        </div>
        <div class="col-lg-6 text-center">
            <div class="auth-preview">
                <div class="card shadow-lg border-0" style="max-width: 400px; margin: 0 auto;">
                    <div class="card-body p-4">
                        <div class="text-center mb-3">
                            <i class="fas fa-store fa-2x text-primary"></i>
                        </div>
                        <h5 class="card-title text-center">Webstore</h5>
                        <p class="text-muted text-center small">Hệ thống quản lý cửa hàng hiện đại</p>
                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-sm" disabled>
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </button>
                            <button class="btn btn-outline-primary btn-sm" disabled>
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
