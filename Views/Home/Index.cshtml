@model Webstore.Models.StatisticsViewModel

@{
    ViewData["Title"] = "Dashboard Quản Trị";
}

<!-- Dashboard Header -->
<div class="dash-header">
    <div class="dash-header-left">
        <h1 class="dash-title"><i class="fas fa-tachometer-alt"></i> Dashboard Quản Trị</h1>
        <p class="dash-subtitle">Tổng quan hoạt động kinh doanh</p>
    </div>
    <div class="dash-header-right">
        <div class="dash-date-badge">
            <i class="far fa-calendar-alt"></i>
            <span>@DateTime.Now.ToString("dd/MM/yyyy")</span>
        </div>
        <button class="dash-refresh-btn" onclick="window.location.reload()">
            <i class="fas fa-sync-alt"></i>
        </button>
    </div>
</div>

<!-- Stats Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-blue">
            <div class="kpi-icon-wrap"><i class="fas fa-shopping-cart"></i></div>
            <div class="kpi-body">
                <span class="kpi-label">Tổng Đơn Hàng</span>
                <span class="kpi-value" data-count="@Model.TotalOrders">@Model.TotalOrders.ToString("N0")</span>
                <span class="kpi-change kpi-up"><i class="fas fa-arrow-up"></i> +@Model.TodayOrders hôm nay</span>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-green">
            <div class="kpi-icon-wrap"><i class="fas fa-wallet"></i></div>
            <div class="kpi-body">
                <span class="kpi-label">Tổng Doanh Thu</span>
                <span class="kpi-value">@FormatCurrency(Model.TotalRevenue)</span>
                <span class="kpi-change kpi-up"><i class="fas fa-arrow-up"></i> +@FormatCurrency(Model.TodayRevenue) hôm nay</span>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-orange">
            <div class="kpi-icon-wrap"><i class="fas fa-box-open"></i></div>
            <div class="kpi-body">
                <span class="kpi-label">Sản Phẩm Trong Kho</span>
                <span class="kpi-value" data-count="@Model.TotalStock">@Model.TotalStock.ToString("N0")</span>
                <span class="kpi-change kpi-warn"><i class="fas fa-exclamation-triangle"></i> @Model.PendingOrders đơn chờ duyệt</span>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="kpi-card kpi-purple">
            <div class="kpi-icon-wrap"><i class="fas fa-users"></i></div>
            <div class="kpi-body">
                <span class="kpi-label">Khách Hàng</span>
                <span class="kpi-value" data-count="@Model.AccountCount">@Model.AccountCount.ToString("N0")</span>
                <span class="kpi-change kpi-up"><i class="fas fa-user-plus"></i> Tăng trưởng ổn định</span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions-bar mb-4">
    <span class="qa-title">Thao Tác Nhanh</span>
    <div class="qa-buttons">
        <a asp-controller="Products" asp-action="Index" class="qa-btn"><i class="fas fa-box"></i> Quản lý sản phẩm</a>
        <a asp-controller="Orders" asp-action="Index" class="qa-btn"><i class="fas fa-shopping-bag"></i> Quản lý đơn hàng</a>
        <a asp-controller="Categories" asp-action="Index" class="qa-btn"><i class="fas fa-tags"></i> Quản lý danh mục</a>
        <a asp-controller="Suppliers" asp-action="Index" class="qa-btn"><i class="fas fa-truck"></i> Quản lý nhà cung cấp</a>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="dash-card h-100">
            <div class="dash-card-header">
                <h5><i class="fas fa-chart-area me-2"></i>Biểu Đồ Doanh Thu 7 Ngày</h5>
                <span class="dash-badge-accent">VND</span>
            </div>
            <div class="dash-card-body">
                <canvas id="revenueChart" style="max-height:320px;"></canvas>
            </div>
        </div>
    </div>
    <!-- Order Status -->
    <div class="col-lg-4">
        <div class="dash-card h-100">
            <div class="dash-card-header">
                <h5><i class="fas fa-chart-pie me-2"></i>Trạng Thái Đơn Hàng</h5>
            </div>
            <div class="dash-card-body d-flex flex-column align-items-center">
                <div class="doughnut-wrapper">
                    <canvas id="statusChart"></canvas>
                    <div class="doughnut-center">
                        <span class="doughnut-total">@Model.TotalOrders</span>
                        <span class="doughnut-label">Tổng Đơn</span>
                    </div>
                </div>
                <div class="status-legend">
                    <div class="legend-item"><span class="legend-dot" style="background:#2a9d8f"></span>Đã giao <strong>@Model.DeliveredOrders</strong></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#ffb703"></span>Đang xử lý <strong>@Model.ProcessingOrders</strong></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#0077b6"></span>Mới <strong>@Model.NewOrders</strong></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#e63946"></span>Đã hủy <strong>@Model.CanceledOrders</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row: Top Products + Recent Orders -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="dash-card">
            <div class="dash-card-header">
                <h5><i class="fas fa-fire me-2"></i>Sản Phẩm Bán Chạy</h5>
                <a asp-controller="Products" asp-action="Index" class="dash-link">Xem tất cả</a>
            </div>
            <div class="dash-card-body p-0">
                <table class="dash-table">
                    <thead><tr><th>Sản phẩm</th><th class="text-center">Đã bán</th><th class="text-end">Doanh thu</th></tr></thead>
                    <tbody>
                        @foreach (var p in Model.TopProducts.Take(4))
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="prod-thumb">
                                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                                            { <img src="@p.ImageUrl" alt="product"> }
                                            else
                                            { <i class="fas fa-laptop"></i> }
                                        </div>
                                        <span class="fw-600">@p.ProductName</span>
                                    </div>
                                </td>
                                <td class="text-center"><span class="sold-badge">@p.TotalSold</span></td>
                                <td class="text-end text-success fw-bold">@p.TotalRevenue.ToString("N0")₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="dash-card">
            <div class="dash-card-header">
                <h5><i class="fas fa-clock me-2"></i>Đơn Hàng Gần Đây</h5>
                <a asp-controller="Orders" asp-action="Index" class="dash-link">Chi tiết</a>
            </div>
            <div class="dash-card-body p-0">
                <table class="dash-table">
                    <thead><tr><th>ID</th><th>Khách hàng</th><th class="text-end">Trạng thái</th></tr></thead>
                    <tbody>
                        @foreach (var o in Model.RecentOrders.Take(4))
                        {
                            <tr>
                                <td><span class="order-id">#ORD-@o.OrderId</span></td>
                                <td>@o.CustomerName</td>
                                <td class="text-end"><span class="status-pill @GetStatusClass(o.Status)">@TranslateStatus(o.Status)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@functions {
    string FormatCurrency(decimal amount)
    {
        if (amount >= 1_000_000_000) return (amount / 1_000_000_000).ToString("0.#") + "B ₫";
        if (amount >= 1_000_000) return (amount / 1_000_000).ToString("0.#") + "M ₫";
        if (amount >= 1_000) return (amount / 1_000).ToString("0.#") + "K ₫";
        return amount.ToString("N0") + "₫";
    }

    string GetStatusClass(string status) => status switch
    {
        "New" => "pill-new",
        "Processing" => "pill-processing",
        "Delivered" or "Completed" => "pill-delivered",
        "Canceled" => "pill-canceled",
        "Shipped" => "pill-shipped",
        _ => "pill-default"
    };

    string TranslateStatus(string status) => status switch
    {
        "New" => "Mới",
        "Processing" => "Đang xử lý",
        "Delivered" => "Đã giao",
        "Completed" => "Hoàn thành",
        "Canceled" => "Đã hủy",
        "Shipped" => "Đang giao",
        "Pending" => "Chờ duyệt",
        _ => status
    };
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Revenue Chart
            const revCtx = document.getElementById('revenueChart').getContext('2d');
            const gradient = revCtx.createLinearGradient(0, 0, 0, 320);
            gradient.addColorStop(0, 'rgba(0, 119, 182, 0.25)');
            gradient.addColorStop(1, 'rgba(0, 119, 182, 0.01)');

            new Chart(revCtx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.RevenueByDay.Select(d => $"'{d.Date:dd/MM}'")))],
                    datasets: [{
                        label: 'Doanh thu (₫)',
                        data: [@string.Join(",", Model.RevenueByDay.Select(d => d.Revenue))],
                        borderColor: '#0077b6',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#0077b6',
                        pointBorderWidth: 3,
                        pointRadius: 5,
                        pointHoverRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)', borderDash: [5, 5] }, ticks: { callback: v => (v / 1000000) + 'M', font: { weight: 600 } } },
                        x: { grid: { display: false }, ticks: { font: { weight: 600 } } }
                    },
                    interaction: { intersect: false, mode: 'index' }
                }
            });

            // Doughnut Chart
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Đã giao', 'Đang xử lý', 'Mới', 'Đã hủy'],
                    datasets: [{
                        data: [@Model.DeliveredOrders, @Model.ProcessingOrders, @Model.NewOrders, @Model.CanceledOrders],
                        backgroundColor: ['#2a9d8f', '#ffb703', '#0077b6', '#e63946'],
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '72%',
                    plugins: { legend: { display: false }, tooltip: { backgroundColor: '#1e293b', cornerRadius: 10, padding: 12 } }
                }
            });

            // Animate KPI numbers
            document.querySelectorAll('.kpi-value[data-count]').forEach(el => {
                const target = parseInt(el.dataset.count);
                if (isNaN(target) || target === 0) return;
                let current = 0;
                const step = Math.ceil(target / 40);
                const timer = setInterval(() => {
                    current += step;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = current.toLocaleString('vi-VN');
                }, 30);
            });
        });
    </script>
}

<style>
    /* ============ DASHBOARD HEADER ============ */
    .dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
    .dash-title { font-size: 1.6rem; font-weight: 800; color: #1e293b; margin: 0; }
    .dash-title i { color: #0077b6; margin-right: 8px; }
    .dash-subtitle { font-size: 0.85rem; color: #94a3b8; margin: 4px 0 0; }
    .dash-header-right { display: flex; align-items: center; gap: 10px; }
    .dash-date-badge {
        display: flex; align-items: center; gap: 8px;
        background: white; border: 1px solid #e2e8f0;
        padding: 8px 16px; border-radius: 12px;
        font-weight: 600; font-size: 0.88rem; color: #475569;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .dash-date-badge i { color: #0077b6; }
    .dash-refresh-btn {
        width: 40px; height: 40px; border: 1px solid #e2e8f0;
        background: white; border-radius: 12px; cursor: pointer;
        color: #64748b; font-size: 0.95rem;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.25s; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .dash-refresh-btn:hover { background: #0077b6; color: white; border-color: #0077b6; transform: rotate(180deg); }

    /* ============ KPI CARDS ============ */
    .kpi-card {
        background: white; border-radius: 20px; padding: 22px 24px;
        display: flex; align-items: center; gap: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.04);
        transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative; overflow: hidden;
    }
    .kpi-card::after {
        content: ''; position: absolute; top: 0; right: 0;
        width: 100px; height: 100px; border-radius: 50%;
        opacity: 0.06; transform: translate(30px, -30px);
    }
    .kpi-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.1); }
    .kpi-icon-wrap {
        width: 56px; height: 56px; border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; flex-shrink: 0;
    }
    .kpi-blue .kpi-icon-wrap { background: rgba(0,119,182,0.1); color: #0077b6; }
    .kpi-blue::after { background: #0077b6; }
    .kpi-green .kpi-icon-wrap { background: rgba(16,185,129,0.1); color: #10b981; }
    .kpi-green::after { background: #10b981; }
    .kpi-orange .kpi-icon-wrap { background: rgba(245,158,11,0.1); color: #f59e0b; }
    .kpi-orange::after { background: #f59e0b; }
    .kpi-purple .kpi-icon-wrap { background: rgba(139,92,246,0.1); color: #8b5cf6; }
    .kpi-purple::after { background: #8b5cf6; }

    .kpi-body { display: flex; flex-direction: column; min-width: 0; }
    .kpi-label { font-size: 0.78rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
    .kpi-value { font-size: 1.65rem; font-weight: 800; color: #1e293b; line-height: 1.2; }
    .kpi-change { font-size: 0.75rem; font-weight: 600; margin-top: 4px; }
    .kpi-up { color: #10b981; }
    .kpi-warn { color: #f59e0b; }

    /* ============ QUICK ACTIONS BAR ============ */
    .quick-actions-bar {
        background: white; border-radius: 16px; padding: 16px 24px;
        display: flex; align-items: center; gap: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.04);
        flex-wrap: wrap;
    }
    .qa-title { font-weight: 700; color: #1e293b; font-size: 0.9rem; white-space: nowrap; }
    .qa-buttons { display: flex; gap: 10px; flex-wrap: wrap; }
    .qa-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 9px 18px; border-radius: 10px;
        border: 1.5px solid #e2e8f0; background: #f8fafc;
        font-size: 0.84rem; font-weight: 600; color: #475569;
        transition: all 0.25s; cursor: pointer;
    }
    .qa-btn:hover { background: #0077b6; color: white; border-color: #0077b6; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,119,182,0.25); }
    .qa-btn i { font-size: 0.9rem; }

    /* ============ DASH CARD ============ */
    .dash-card {
        background: white; border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.04);
        overflow: hidden;
    }
    .dash-card-header {
        padding: 20px 24px; display: flex; justify-content: space-between; align-items: center;
        border-bottom: 1px solid #f1f5f9;
    }
    .dash-card-header h5 { margin: 0; font-weight: 700; font-size: 1rem; color: #1e293b; }
    .dash-card-body { padding: 24px; }
    .dash-badge-accent {
        background: rgba(0,119,182,0.1); color: #0077b6;
        padding: 4px 14px; border-radius: 8px;
        font-size: 0.78rem; font-weight: 700;
    }
    .dash-link { color: #0077b6; font-size: 0.84rem; font-weight: 600; }
    .dash-link:hover { text-decoration: underline; }

    /* ============ DOUGHNUT ============ */
    .doughnut-wrapper { position: relative; width: 200px; height: 200px; margin-bottom: 20px; }
    .doughnut-center {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        text-align: center; display: flex; flex-direction: column;
    }
    .doughnut-total { font-size: 2rem; font-weight: 800; color: #1e293b; line-height: 1; }
    .doughnut-label { font-size: 0.75rem; color: #94a3b8; font-weight: 600; }

    .status-legend { width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: #64748b; font-weight: 500; }
    .legend-item strong { margin-left: auto; color: #1e293b; font-weight: 700; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

    /* ============ DASH TABLE ============ */
    .dash-table { width: 100%; border-collapse: collapse; }
    .dash-table thead th {
        padding: 12px 24px; font-size: 0.72rem; text-transform: uppercase;
        letter-spacing: 0.5px; color: #94a3b8; font-weight: 700;
        background: #f8fafc; border-bottom: 1px solid #f1f5f9;
    }
    .dash-table tbody td { padding: 14px 24px; font-size: 0.88rem; border-bottom: 1px solid #f8fafc; color: #334155; }
    .dash-table tbody tr { transition: background 0.2s; }
    .dash-table tbody tr:hover { background: #f8fafc; }
    .dash-table tbody tr:last-child td { border-bottom: none; }

    .prod-thumb {
        width: 40px; height: 40px; border-radius: 10px; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0;
    }
    .prod-thumb img { width: 100%; height: 100%; object-fit: contain; }
    .fw-600 { font-weight: 600; }
    .sold-badge { background: #f1f5f9; padding: 4px 14px; border-radius: 8px; font-weight: 700; font-size: 0.82rem; color: #475569; }
    .order-id { color: #0077b6; font-weight: 700; }

    /* ============ STATUS PILLS ============ */
    .status-pill { padding: 5px 14px; border-radius: 50px; font-size: 0.76rem; font-weight: 700; display: inline-block; }
    .pill-new { background: rgba(0,119,182,0.1); color: #0077b6; }
    .pill-processing { background: rgba(245,158,11,0.1); color: #f59e0b; }
    .pill-delivered { background: rgba(16,185,129,0.1); color: #10b981; }
    .pill-canceled { background: rgba(239,68,68,0.1); color: #ef4444; }
    .pill-shipped { background: rgba(59,130,246,0.1); color: #3b82f6; }
    .pill-default { background: #f1f5f9; color: #64748b; }

    /* ============ RESPONSIVE ============ */
    @@media (max-width: 768px) {
        .dash-header { flex-direction: column; align-items: flex-start; }
        .kpi-value { font-size: 1.3rem; }
        .status-legend { grid-template-columns: 1fr; }
    }
</style>
