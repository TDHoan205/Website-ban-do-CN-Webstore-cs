@model Webstore.Models.PagedList<Webstore.Models.ReceiptShipment>
@{
    ViewData["Title"] = "Quản lý Nhật Ký Nhập/Xuất Kho";
}

<h2>Quản lý Nhật Ký Nhập/Xuất Kho</h2>

<div class="row mb-3">
    <div class="col-md-8">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control me-2" placeholder="Tìm theo ID, sản phẩm, loại, đơn hàng..." />
            <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
            <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-success">Thêm mới</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row mb-2">
    <div class="col-md-6">
        <span>Hiển thị @Model.Count() trong tổng số @Model.TotalCount nhật ký</span>
    </div>
    <div class="col-md-6 text-end">
        <form method="get" asp-action="Index" class="d-inline">
            <input type="hidden" name="search" value="@ViewBag.Search" />
            <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
            <label>Số dòng/trang:</label>
            <select name="pageSize" onchange="this.form.submit()" class="form-select d-inline-block w-auto">
                <option value="5" selected="@(ViewBag.PageSize == 5)">5</option>
                <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
            </select>
        </form>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.MovementIdSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize">
                    ID Nhật Ký
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.ProductSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize">
                    Sản Phẩm
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.TypeSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize">
                    Loại
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.QuantitySortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize">
                    Số Lượng
                </a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize">
                    Ngày
                </a>
            </th>
            <th>Đơn Hàng Liên Quan</th>
            <th style="width:180px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MovementId</td>
                <td>@item.MovementId</td>
                <td>@item.Product?.Name</td>
                <td>
                    <span class="badge @(item.MovementType == "IN" ? "bg-success" : "bg-danger")">
                        @(item.MovementType == "IN" ? "NHẬP" : "XUẤT")
                    </span>
                </td>
                <td>@item.Quantity</td>
                <td>@item.MovementDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(item.RelatedOrder?.OrderId != null ? "#" + item.RelatedOrder.OrderId : "Không")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MovementId" class="btn btn-sm btn-primary">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.MovementId" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (Model.HasPrevious)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="1" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">Đầu</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">Trước</a>
                </li>
            }
            
            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">@i</a>
                </li>
            }
            
            @if (Model.HasNext)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">Sau</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">Cuối</a>
                </li>
            }
        </ul>
    </nav>
}
