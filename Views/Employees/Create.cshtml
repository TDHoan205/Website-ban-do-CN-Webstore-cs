@model Webstore.Models.Employee
@{
    ViewData["Title"] = "Thêm Nhân Viên";
    var accounts = ViewBag.Accounts as List<Webstore.Models.Account> ?? new List<Webstore.Models.Account>();
}

<h2>Thêm Nhân Viên</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">Tài khoản</label>
        <select asp-for="AccountId" class="form-select">
            <option value="">-- Chọn tài khoản --</option>
            @foreach (var account in accounts)
            {
                <option value="@account.AccountId">@account.Username (@account.FullName)</option>
            }
        </select>
        <span asp-validation-for="AccountId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="EmployeeCode" class="form-label">Mã nhân viên</label>
        <input asp-for="EmployeeCode" class="form-control" />
        <span asp-validation-for="EmployeeCode" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Position" class="form-label">Chức vụ</label>
        <input asp-for="Position" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Department" class="form-label">Phòng ban</label>
        <input asp-for="Department" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
