@model Webstore.Models.StatisticsViewModel

@{
    ViewData["Title"] = "TechStore Admin Dashboard";
}

<div class="dashboard-wrapper">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-800 text-gradient mb-1">Bảng Điều Khiển Quản Trị</h1>
            <p class="text-muted mb-0">Theo dõi hoạt động kinh doanh thời gian thực</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-glass" onclick="window.location.reload()">
                <i class="fas fa-sync-alt me-2"></i>Làm mới
            </button>
            <div class="date-display btn btn-glass">
                <i class="far fa-calendar-alt me-2 text-primary"></i>@DateTime.Now.ToString("dd/MM/yyyy")
            </div>
        </div>
    </div>

    <!-- Quick Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stats-card stats-primary">
                <div class="stats-card-body">
                    <div class="stats-icon"><i class="fas fa-shopping-cart"></i></div>
                    <div class="stats-info">
                        <h3 class="stats-value">@Model.TotalOrders</h3>
                        <p class="stats-label">Tổng Đơn Hàng</p>
                    </div>
                </div>
                <div class="stats-card-footer">
                    <span class="text-success"><i class="fas fa-arrow-up me-1"></i>+@Model.TodayOrders hôm nay</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card stats-success">
                <div class="stats-card-body">
                    <div class="stats-icon"><i class="fas fa-wallet"></i></div>
                    <div class="stats-info">
                        <h3 class="stats-value">@Model.TotalRevenue.ToString("N0")₫</h3>
                        <p class="stats-label">Tổng Doanh Thu</p>
                    </div>
                </div>
                <div class="stats-card-footer">
                    <span class="text-success"><i class="fas fa-arrow-up me-1"></i>+@Model.TodayRevenue.ToString("N0")₫ hôm nay</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card stats-warning">
                <div class="stats-card-body">
                    <div class="stats-icon"><i class="fas fa-box-open"></i></div>
                    <div class="stats-info">
                        <h3 class="stats-value">@Model.TotalStock</h3>
                        <p class="stats-label">Sản Phẩm Trong Kho</p>
                    </div>
                </div>
                <div class="stats-card-footer">
                    <span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i>@Model.PendingOrders đơn chờ duyệt</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card stats-info">
                <div class="stats-card-body">
                    <div class="stats-icon"><i class="fas fa-users"></i></div>
                    <div class="stats-info">
                        <h3 class="stats-value">@Model.AccountCount</h3>
                        <p class="stats-label">Khách Hàng</p>
                    </div>
                </div>
                <div class="stats-card-footer">
                    <span class="text-primary"><i class="fas fa-user-plus me-1"></i>Tăng trưởng ổn định</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="glass-card h-100">
                <div class="card-header-custom">
                    <h5 class="mb-0 fw-bold">Biểu Đồ Doanh Thu 7 Ngày</h5>
                    <div class="badge bg-primary-soft">VND</div>
                </div>
                <div class="card-body-custom pt-4">
                    <canvas id="revenueChart" style="max-height: 350px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-card h-100">
                <div class="card-header-custom">
                    <h5 class="mb-0 fw-bold">Trạng Thái Đơn Hàng</h5>
                </div>
                <div class="card-body-custom d-flex flex-column align-items-center justify-content-center pt-4">
                    <canvas id="statusChart" style="max-height: 250px;"></canvas>
                    <div class="status-legend mt-4 w-100">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-primary me-2"></i>Mới</span>
                            <span class="fw-bold">@Model.NewOrders</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-warning me-2"></i>Đang xử lý</span>
                            <span class="fw-bold">@Model.ProcessingOrders</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-success me-2"></i>Đã giao</span>
                            <span class="fw-bold">@Model.DeliveredOrders</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span><i class="fas fa-circle text-danger me-2"></i>Đã hủy</span>
                            <span class="fw-bold">@Model.CanceledOrders</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Lists Row -->
    <div class="row g-4">
        <!-- Top Products -->
        <div class="col-lg-6">
            <div class="glass-card">
                <div class="card-header-custom">
                    <h5 class="mb-0 fw-bold">Sản Phẩm Bán Chạy</h5>
                    <a asp-controller="Products" asp-action="Index" class="text-primary text-decoration-none small">Xem tất cả</a>
                </div>
                <div class="card-body-custom p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Đã bán</th>
                                    <th class="text-end pe-4">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.TopProducts.Take(5))
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="product-thumb me-3">
                                                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                                                    {
                                                        <img src="@p.ImageUrl" alt="product">
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-laptop"></i>
                                                    }
                                                </div>
                                                <span class="fw-600">@p.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center"><span class="badge badge-pill bg-light text-dark">@p.TotalSold</span></td>
                                        <td class="text-end pe-4 text-success fw-bold">@p.TotalRevenue.ToString("N0")₫</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Orders -->
        <div class="col-lg-6">
            <div class="glass-card">
                <div class="card-header-custom">
                    <h5 class="mb-0 fw-bold">Đơn Hàng Gần Đây</h5>
                    <a asp-controller="Orders" asp-action="Index" class="text-primary text-decoration-none small">Chi tiết</a>
                </div>
                <div class="card-body-custom p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Khách hàng</th>
                                    <th class="text-end pe-4">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in Model.RecentOrders.Take(5))
                                {
                                    <tr>
                                        <td class="ps-4"><span class="fw-bold">#@o.OrderId</span></td>
                                        <td>
                                            <div class="fw-600">@o.CustomerName</div>
                                            <div class="text-muted x-small">@o.OrderDate.ToString("dd/MM HH:mm")</div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <span class="badge @GetStatusBadgeClass(o.Status)">@o.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success-soft",
        "New" => "bg-primary-soft",
        "Pending" => "bg-warning-soft",
        "Canceled" => "bg-danger-soft",
        _ => "bg-light-soft text-dark"
    };
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Revenue Chart
            const revCtx = document.getElementById('revenueChart').getContext('2d');
            new Chart(revCtx, {
                type: 'line',
                data: {
                    labels: [@Html.Raw(string.Join(",", Model.RevenueByDay.Select(d => $"'{d.Date:dd/MM}'")))],
                    datasets: [{
                        label: 'Doanh thu (₫)',
                        data: [@string.Join(",", Model.RevenueByDay.Select(d => d.Revenue))],
                        borderColor: '#0077b6',
                        backgroundColor: 'rgba(0, 119, 182, 0.1)',
                        borderWidth: 3,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#0077b6',
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [5, 5] }, ticks: { callback: v => (v / 1000000) + 'M' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Status Chart
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Mới', 'Đã duyệt', 'Đã giao', 'Hủy'],
                    datasets: [{
                        data: [@Model.NewOrders, @Model.ProcessingOrders, @Model.DeliveredOrders, @Model.CanceledOrders],
                        backgroundColor: ['#0077b6', '#ffb703', '#2a9d8f', '#e63946'],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: { legend: { display: false } }
                }
            });
        });
    </script>
}

<style>
    :root {
        --primary: #0077b6;
        --primary-soft: rgba(0, 119, 182, 0.1);
        --success: #2a9d8f;
        --success-soft: rgba(42, 157, 143, 0.1);
        --warning: #ffb703;
        --warning-soft: rgba(255, 183, 3, 0.1);
        --danger: #e63946;
        --danger-soft: rgba(230, 57, 70, 0.1);
        --light-soft: rgba(200, 200, 200, 0.1);
        --radius-lg: 24px;
        --radius-md: 16px;
        --glass: rgba(255, 255, 255, 0.8);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    .dashboard-wrapper { padding: 2rem; background: #f8fafc; min-height: 100vh; }
    .text-gradient { background: linear-gradient(135deg, #003049, var(--primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .fw-800 { font-weight: 800; }
    .fw-600 { font-weight: 600; }
    .x-small { font-size: 0.7rem; }

    .btn-glass { 
        background: var(--glass); 
        backdrop-filter: blur(10px); 
        border: 1px solid rgba(255,255,255,0.3); 
        box-shadow: var(--shadow);
        color: #475569;
        font-weight: 600;
        padding: 0.6rem 1.2rem;
        border-radius: 12px;
    }
    .btn-glass:hover { background: white; color: var(--primary); }

    /* Stats Cards */
    .stats-card { 
        background: white; 
        border-radius: var(--radius-md); 
        padding: 1.5rem; 
        box-shadow: var(--shadow);
        border: 1px solid rgba(0,0,0,0.02);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .stats-card:hover { transform: translateY(-10px); }
    .stats-card-body { display: flex; align-items: center; gap: 1.2rem; margin-bottom: 1rem; }
    .stats-icon { 
        width: 56px; height: 56px; border-radius: 16px; 
        display: flex; align-items: center; justify-content: center; 
        font-size: 1.5rem; 
    }
    .stats-value { font-size: 1.5rem; font-weight: 800; margin-bottom: 0px; color: #1e293b; }
    .stats-label { font-size: 0.85rem; color: #64748b; margin-bottom: 0; font-weight: 600; }
    .stats-card-footer { font-size: 0.8rem; font-weight: 600; border-top: 1px solid #f1f5f9; pt: 0.8rem; }

    .stats-primary .stats-icon { background: var(--primary-soft); color: var(--primary); }
    .stats-success .stats-icon { background: var(--success-soft); color: var(--success); }
    .stats-warning .stats-icon { background: var(--warning-soft); color: var(--warning); }
    .stats-info    .stats-icon { background: var(--light-soft); color: #475569; }

    /* Glass Card */
    .glass-card {
        background: var(--glass);
        backdrop-filter: blur(20px);
        border-radius: var(--radius-lg);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: var(--shadow);
        overflow: hidden;
    }
    .card-header-custom { 
        padding: 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.05); 
        display: flex; justify-content: space-between; align-items: center; 
    }
    .card-body-custom { padding: 1.5rem; }

    /* Product UI */
    .product-thumb {
        width: 44px; height: 44px; border-radius: 10px; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center; overflow: hidden;
    }
    .product-thumb img { width: 100%; height: 100%; object-fit: contain; }

    /* Badges */
    .badge { padding: 0.4em 0.8em; border-radius: 8px; font-weight: 700; font-size: 0.75rem; border: none; }
    .bg-primary-soft { background: var(--primary-soft); color: var(--primary); }
    .bg-success-soft { background: var(--success-soft); color: var(--success); }
    .bg-warning-soft { background: var(--warning-soft); color: var(--warning); }
    .bg-danger-soft  { background: var(--danger-soft); color: var(--danger); }

    /* Table override */
    .table thead th { 
        background: rgba(0,0,0,0.02); color: #64748b; font-size: 0.75rem; 
        text-transform: uppercase; letter-spacing: 0.05em; border: none; 
    }
    .table td { border-color: rgba(0,0,0,0.03); padding-top: 1rem; padding-bottom: 1rem; }
</style>
