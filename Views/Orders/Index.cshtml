@model Webstore.Models.PagedList<Webstore.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn Hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-shopping-bag me-2 text-primary"></i>Quản lý Đơn Hàng
    </h2>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <form method="get" asp-action="Index" class="d-flex">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control me-2" placeholder="Tìm theo ID, tài khoản, trạng thái..." />
                    <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                    <button type="submit" class="btn btn-primary" style="white-space:nowrap"><i class="fas fa-search me-1"></i>Tìm kiếm</button>
                </form>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Thêm mới
                </a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<vc:paged-list-pager
    current-page="@Model.CurrentPage"
    total-pages="@Model.TotalPages"
    total-count="@Model.TotalCount"
    page-size="@Model.PageSize"
    has-previous="@Model.HasPrevious"
    has-next="@Model.HasNext"
    search="@ViewBag.Search"
    sort-order="@ViewBag.SortOrder"
    controller-name="Orders"
    action-name="Index">
</vc:paged-list-pager>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-scroll-container">
            <table class="table table-hover mb-0 table-zebra">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.OrderIdSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                ID Đơn Hàng <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Ngày Đặt <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.AmountSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Tổng Tiền <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.StatusSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Trạng Thái <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>Tài Khoản</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.OrderId</td>
                            <td><strong>#@item.OrderId</strong></td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-primary">@item.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                @{
                                    var statusClass = item.Status switch {
                                        "Pending" => "bg-warning text-dark",
                                        "Processing" => "bg-info",
                                        "Shipped" => "bg-primary",
                                        "Completed" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                    var statusIcon = item.Status switch {
                                        "Pending" => "fa-clock",
                                        "Processing" => "fa-spinner fa-spin",
                                        "Shipped" => "fa-truck",
                                        "Completed" => "fa-check-circle",
                                        "Cancelled" => "fa-times-circle",
                                        _ => "fa-question-circle"
                                    };
                                }
                                <span class="badge @statusClass">
                                    <i class="fas @statusIcon me-1"></i>@item.Status
                                </span>
                            </td>
                            <td>
                                <i class="fas fa-user me-1 text-muted"></i>@(item.Account?.Username ?? "N/A")
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-secondary btn-details" data-id="@item.OrderId" title="Chi tiết">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <tr class="order-details-row d-none" data-order-id="@item.OrderId">
                            <td colspan="7" class="p-0">
                                <div class="p-3 bg-light">Đang tải...</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            function toggleDetails(button) {
                var id = button.getAttribute('data-id');
                var detailsRow = document.querySelector('tr.order-details-row[data-order-id="' + id + '"]');
                if (!detailsRow) return;

                var isHidden = detailsRow.classList.contains('d-none');

                if (isHidden) {
                    var contentDiv = detailsRow.querySelector('div');
                    if (contentDiv && contentDiv.textContent.trim() === 'Đang tải...') {
                        fetch('/Orders/DetailsPartial/' + id)
                            .then(function (res) { if (!res.ok) throw new Error('Network response was not ok'); return res.text(); })
                            .then(function (html) {
                                detailsRow.querySelector('td').innerHTML = html;
                                detailsRow.classList.remove('d-none');
                            })
                            .catch(function (err) {
                                detailsRow.querySelector('td').innerHTML = '<div class="p-2 text-danger">Không tải được chi tiết: ' + err.message + '</div>';
                                detailsRow.classList.remove('d-none');
                            });
                    } else {
                        detailsRow.classList.remove('d-none');
                    }
                } else {
                    detailsRow.classList.add('d-none');
                }
            }

            document.querySelectorAll('.btn-details').forEach(function(btn){
                btn.addEventListener('click', function(e){ toggleDetails(e.currentTarget); });
            });
        })();
    </script>
}
