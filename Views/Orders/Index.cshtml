@model Webstore.Models.PagedList<Webstore.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn Hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-shopping-bag me-2 text-primary"></i>Quản lý Đơn Hàng
    </h2>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <form method="get" asp-action="Index" class="d-flex">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control me-2" placeholder="Tìm theo ID, tài khoản, trạng thái..." />
                    <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i>Tìm kiếm
                    </button>
                </form>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Thêm mới
                </a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <span class="text-muted">
                <i class="fas fa-list me-1"></i>
                Hiển thị @Model.Count() trong tổng số @Model.TotalCount đơn hàng
            </span>
            <form method="get" asp-action="Index" class="d-inline">
                <input type="hidden" name="search" value="@ViewBag.Search" />
                <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                <label class="me-2">Số dòng/trang:</label>
                <select name="pageSize" onchange="this.form.submit()" class="form-select d-inline-block w-auto">
                    <option value="5" selected="@(ViewBag.PageSize == 5)">5</option>
                    <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                    <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                    <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                </select>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.OrderIdSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                ID Đơn Hàng <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Ngày Đặt <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.AmountSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Tổng Tiền <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.StatusSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Trạng Thái <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>Tài Khoản</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.OrderId</td>
                            <td><strong>#@item.OrderId</strong></td>
                            <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-bold text-primary">@item.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                @{
                                    var statusClass = item.Status switch {
                                        "Pending" => "bg-warning text-dark",
                                        "Processing" => "bg-info",
                                        "Shipped" => "bg-primary",
                                        "Completed" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                    var statusIcon = item.Status switch {
                                        "Pending" => "fa-clock",
                                        "Processing" => "fa-spinner fa-spin",
                                        "Shipped" => "fa-truck",
                                        "Completed" => "fa-check-circle",
                                        "Cancelled" => "fa-times-circle",
                                        _ => "fa-question-circle"
                                    };
                                }
                                <span class="badge @statusClass">
                                    <i class="fas @statusIcon me-1"></i>@item.Status
                                </span>
                            </td>
                            <td>
                                <i class="fas fa-user me-1 text-muted"></i>@(item.Account?.Username ?? "N/A")
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-secondary btn-details" data-id="@item.OrderId" title="Chi tiết">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <tr class="order-details-row d-none" data-order-id="@item.OrderId">
                            <td colspan="7" class="p-0">
                                <div class="p-3 bg-light">Đang tải...</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation mt-4">
        <ul class="pagination justify-content-center mt-4">
            @if (Model.HasPrevious)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="1" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">
                        <i class="fas fa-angle-double-left"></i> Đầu
                    </a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">
                        <i class="fas fa-angle-left"></i> Trước
                    </a>
                </li>
            }

            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">@i</a>
                </li>
            }

            @if (Model.HasNext)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">
                        Sau <i class="fas fa-angle-right"></i>
                    </a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@Model.TotalPages" asp-route-search="@ViewBag.Search" asp-route-sortOrder="@ViewBag.SortOrder" asp-route-pageSize="@ViewBag.PageSize">
                        Cuối <i class="fas fa-angle-double-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        (function(){
            function toggleDetails(button) {
                var id = button.getAttribute('data-id');
                var detailsRow = document.querySelector('tr.order-details-row[data-order-id="' + id + '"]');
                if (!detailsRow) return;

                var isHidden = detailsRow.classList.contains('d-none');

                if (isHidden) {
                    // If content is not loaded yet (checked by inner div text)
                    var contentDiv = detailsRow.querySelector('div');
                    if (contentDiv && contentDiv.textContent.trim() === 'Đang tải...') {
                        fetch('/Orders/DetailsPartial/' + id)
                            .then(function (res) { if (!res.ok) throw new Error('Network response was not ok'); return res.text(); })
                            .then(function (html) {
                                detailsRow.querySelector('td').innerHTML = html;
                                detailsRow.classList.remove('d-none');
                            })
                            .catch(function (err) {
                                detailsRow.querySelector('td').innerHTML = '<div class="p-2 text-danger">Không tải được chi tiết: ' + err.message + '</div>';
                                detailsRow.classList.remove('d-none');
                            });
                    } else {
                        detailsRow.classList.remove('d-none');
                    }
                } else {
                    detailsRow.classList.add('d-none');
                }
            }

            document.querySelectorAll('.btn-details').forEach(function(btn){
                btn.addEventListener('click', function(e){ toggleDetails(e.currentTarget); });
            });
        })();
    </script>
}
