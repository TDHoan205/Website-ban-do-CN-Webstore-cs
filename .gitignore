# =========================================================
# Website-ban-do-CN-Webstore-cs - .gitignore
# =========================================================

## Build outputs - IGNORE ALL
bin/
obj/
[Bb]in/
[Oo]bj/
*.user
*.userosscache
*.suo

## IDE / Editor
.vs/
.vscode/
.idea/
*.swp
*~
.DS_Store

## NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

## Logs
*.log
logs/

## OS
Thumbs.db
ehthumbs.db
.DS_Store
._*

## Database - IGNORE LOCAL DB FILES
*.mdf
*.ldf
*.sqlite
*.db-shm
*.db-wal

## =========================================================
## SECRETS - CRITICAL: Never commit these files!
## =========================================================

# appsettings.json chua secrets - ignore hoan toan
appsettings.json

# Viết đè lên với example (không bao giờ push thật)
appsettings.Development.json
appsettings.Production.json
appsettings.*.json

# SSL Certificates
*.pem
*.key
*.crt

# Connection strings
ConnectionStrings.config
secrets.json

# =========================================================
## TEMPLATE FILES - SHOULD COMMIT
## =========================================================

# Giữ phiên bản example để người khác copy
# appsettings.json.example  ← NÊN commit file này

# =========================================================
## HƯỚNG DẪN CHO TEAM
## =========================================================
#
# SAU KHI CLONE REPO:
# ====================
# 1. Copy appsettings.json.example thanh appsettings.json
# 2. Thay YOUR_SERVER_NAME bang server cua ban
# 3. Chay script SQL de tao database
#
# KHI CO LOI BUILD:
# =================
# 1. Xoa folder obj/ va bin/
# 2. Chay: dotnet build --no-incremental
#
# PUSH CODE:
# ==========
# - KHONG push: appsettings.json, bin/, obj/
# - CHI push: code, views, controllers, models, SQL scripts
#
## =========================================================
